{
  "name": "live-translate",
  "version": "2.0.0",
  "description": "Real-time Japanese-to-English translation overlay",
  "main": "dist/electron/main.js",
  "type": "commonjs",
  "scripts": {
    "postinstall": "node scripts/download-uv.js",
    "dev": "vite",
    "electron": "electron .",
    "dev:all": "tsc --project tsconfig.electron.json && concurrently \"vite --port 5173 --strictPort\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && tsc --project tsconfig.electron.json",
    "start": "npm run build && npm run electron",
    "build:win": "npm run build && electron-builder -w",
    "build:mac": "npm run build && electron-builder -m",
    "build:linux": "npm run build && electron-builder -l",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.livetranslate.app",
    "productName": "Live Translate",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/resources/bin",
        "to": "bin",
        "filter": [
          "uv",
          "uv.exe"
        ]
      },
      {
        "from": "python",
        "to": "python"
      }
    ],
    "icon": "public/icon",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
