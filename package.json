{
  "name": "live-translate",
  "version": "1.0.0",
  "description": "Real-time speech translation application with overlay",
  "main": "dist/electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "build": "vite build && tsc --project tsconfig.electron.json",
    "build:all": "npm run build && electron-builder -mwl",
    "build:win": "npm run build && electron-builder -w",
    "build:mac": "npm run build && electron-builder -m",
    "build:linux": "npm run build && electron-builder -l",
    "start": "npm run build && npm run electron",
    "dev:all": "concurrently \"vite\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.livetranslate.app",
    "productName": "Live Translate",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.gz"
      ]
    }
  }
}
